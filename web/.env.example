# Локально по умолчанию SQLite (файл prisma/dev.db). Для PostgreSQL замените строку.
DATABASE_URL="file:./prisma/dev.db"

AUTH_SECRET="replace-with-long-random-string"
# Обязателен для NextAuth (админ-панели)
# Ключ шифрования ПДн (ФИО, телефон, email в заявках). Мин. 16 символов; в production обязателен.
PERSONAL_DATA_ENCRYPTION_KEY="replace-with-long-random-secret-for-pii"

# Опционально: ИИ для брифа/КП (без передачи ПДн). Без ключа — шаблонная генерация.
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# Секрет для POST /api/documents/generate (заголовок X-Internal-Secret)
INTERNAL_API_SECRET="replace-with-internal-api-secret"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Ключ JavaScript API Яндекс.Карт (подписи у меток на /addresses)
# https://developer.tech.yandex.ru/
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
